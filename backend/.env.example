ENV=development

# Core app
APP_NAME=Career Guidance System API
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Databases
DATABASE_URL=postgresql://postgres:rahulpg@localhost:5432/postgres
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=career_chat_history
MONGODB_HISTORY_COLLECTION=chat_history
MONGODB_RECOMMENDATION_COLLECTION=recommendation_history
MONGODB_FEEDBACK_COLLECTION=recommendation_feedback
MONGODB_PSYCHOMETRIC_COLLECTION=psychometric_profiles
REDIS_URL=redis://localhost:6379/0

# Authentication
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Market API
JOB_MARKET_API_URL=https://remotive.com/api/remote-jobs

# Retrieval-Augmented Generation (RAG)
RAG_ENABLED=true
RAG_TOP_K=4
RAG_CANDIDATE_POOL_SIZE=20

# Optional phase-2 intent model (model-first routing with keyword fallback)
INTENT_MODEL_ENABLED=false
INTENT_MODEL_ARTIFACT_DIR=ml-models/pretrained/intent_model
INTENT_MODEL_MIN_CONFIDENCE=0.5

# Optional phase-2 user preference model (blended with heuristic profile)
USER_PREFERENCE_MODEL_ENABLED=false
USER_PREFERENCE_MODEL_ARTIFACT_PATH=ml-models/pretrained/user_modeling/user_preference_model.pkl
USER_PREFERENCE_MODEL_ALPHA=0.35

# Optional phase-2 psychometric model (predicts primary domain)
PSYCHOMETRIC_MODEL_ENABLED=false
PSYCHOMETRIC_MODEL_ARTIFACT_PATH=ml-models/pretrained/psychometric_model/psychometric_model.pkl

# Optional phase-2 collaborative-filtering recommender (hybrid scoring)
CF_MODEL_ENABLED=false
CF_MODEL_ARTIFACT_PATH=ml-models/pretrained/cf_model
CF_MODEL_ALPHA=0.25

# Optional phase-2 bandit / RL exploration (epsilon-greedy arm selection)
BANDIT_ENABLED=false
BANDIT_ARTIFACT_PATH=ml-models/pretrained/bandit
BANDIT_EPSILON=0.1

# LLM reply safety filter (pattern-based; enabled by default)
SAFETY_FILTER_ENABLED=true

# Optional LLM runtime (toggle provider between local Ollama, cloud OpenAI, and Groq)
LLM_ENABLED=true
# Providers: ollama (local), openai (cloud), groq (cloud - free tier available)
LLM_PROVIDER=ollama
# Ollama: http://localhost:11434 (local)
# OpenAI: https://api.openai.com/v1 (cloud)
# Groq: https://api.groq.com/openai/v1 (cloud)
LLM_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=tinyllama:latest
LLM_FINETUNED_MODEL=
LLM_REQUEST_TIMEOUT_SECONDS=240
CHAT_REPLY_MAX_SENTENCES=40
LLM_RAG_CONTEXT_MAX_CHARS=3000
LLM_REQUIRE_RAG_CONTEXT=true
LLM_OLLAMA_NUM_PREDICT=450
LLM_AUTO_FALLBACK_TO_OPENAI=false

# Local full-response profile (same machine, Ollama)
# Copy these values into backend/.env for longer RAG+LLM replies.
# Notes:
# - Increase timeout and generation budget to avoid truncated answers.
# - Keep LLM_REQUIRE_RAG_CONTEXT=true so long answers stay grounded.
# - This stronger profile favors fuller TinyLlama replies at the cost of latency.
#
# LLM_ENABLED=true
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://127.0.0.1:11434
# LLM_MODEL=tinyllama:latest
# LLM_REQUEST_TIMEOUT_SECONDS=240
# CHAT_REPLY_MAX_SENTENCES=40
# LLM_RAG_CONTEXT_MAX_CHARS=3000
# LLM_REQUIRE_RAG_CONTEXT=true
# LLM_OLLAMA_NUM_PREDICT=450
# RAG_TOP_K=6
# RAG_CANDIDATE_POOL_SIZE=24

# Cloud key - OpenAI (required only when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Cloud key - Groq (required only when LLM_PROVIDER=groq)
# Sign up free at https://console.groq.com
# Free tier: 25 requests/min, no rate limiting after that
# Models: llama-3.1-8b-instant (fast), llama-3.3-70b-versatile (best quality), qwen/qwen3-32b
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Optional integrations (future phases)
PINECONE_API_KEY=
WEAVIATE_URL=
